// WASI shim: <mutex> — single-threaded no-op implementations
//
// ICP canisters execute single-threaded, so all locking is a no-op.
// Placing this directory first on the include path lets upstream llama.cpp
// compile unmodified instead of requiring per-file threading patches.
//
// Adapted from instruction-bounded-inference-artifact
// MIT (c) 2026 Julien Aerni, Simeon Fluck, Dustin Becker
#pragma once

// Only shim on WASI. On native builds this directory is still on the
// include path, so fall through to the real system header.
#ifndef __wasi__
#include_next <mutex>
#else


// Pre-empt the system <mutex> and every sub-header it would pull in.
// libc++ guards each piece separately, so each guard must be claimed here.
#define _LIBCPP_MUTEX
#define _LIBCPP___MUTEX_MUTEX_H
#define _LIBCPP___MUTEX_ONCE_FLAG_H
#define _LIBCPP___MUTEX_LOCK_GUARD_H
#define _LIBCPP___MUTEX_UNIQUE_LOCK_H
#define _LIBCPP___MUTEX_TAG_TYPES_H

namespace std {

class mutex {
public:
    void lock() {}
    void unlock() {}
    bool try_lock() { return true; }
};

class recursive_mutex {
public:
    void lock() {}
    void unlock() {}
    bool try_lock() { return true; }
};

struct defer_lock_t { explicit defer_lock_t() = default; };
struct try_to_lock_t { explicit try_to_lock_t() = default; };
struct adopt_lock_t { explicit adopt_lock_t() = default; };

inline constexpr defer_lock_t defer_lock{};
inline constexpr try_to_lock_t try_to_lock{};
inline constexpr adopt_lock_t adopt_lock{};

template <class Mutex>
class unique_lock {
    Mutex* m_ = nullptr;
    bool owned_ = false;
public:
    unique_lock() noexcept = default;
    explicit unique_lock(Mutex& m) : m_(&m), owned_(true) { m_->lock(); }
    unique_lock(Mutex& m, defer_lock_t) noexcept : m_(&m), owned_(false) {}
    unique_lock(Mutex& m, adopt_lock_t) noexcept : m_(&m), owned_(true) {}
    ~unique_lock() { if (owned_ && m_) m_->unlock(); }
    unique_lock(unique_lock&& other) noexcept : m_(other.m_), owned_(other.owned_) {
        other.m_ = nullptr; other.owned_ = false;
    }
    unique_lock& operator=(unique_lock&& other) noexcept {
        if (owned_ && m_) m_->unlock();
        m_ = other.m_; owned_ = other.owned_;
        other.m_ = nullptr; other.owned_ = false;
        return *this;
    }
    void lock() { if (m_) { m_->lock(); owned_ = true; } }
    void unlock() { if (m_) { m_->unlock(); owned_ = false; } }
    bool owns_lock() const noexcept { return owned_; }
    explicit operator bool() const noexcept { return owned_; }
    Mutex* mutex() const noexcept { return m_; }
};

template <class Mutex>
class lock_guard {
    Mutex& m_;
public:
    explicit lock_guard(Mutex& m) : m_(m) { m_.lock(); }
    lock_guard(Mutex& m, adopt_lock_t) : m_(m) {}
    ~lock_guard() { m_.unlock(); }
    lock_guard(const lock_guard&) = delete;
    lock_guard& operator=(const lock_guard&) = delete;
};

} // namespace std

// once_flag / call_once live in the sub-header shim so that transitive
// includes (e.g. <__locale> -> <__mutex/once_flag.h>) also resolve here.
#include <__mutex/once_flag.h>

#endif // __wasi__
